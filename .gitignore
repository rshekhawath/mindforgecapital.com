# ── IP — factor models, weights, backtests (LOCAL ONLY, never commit) ────────
# All MindForge factor IP lives in the sibling folder ~/Desktop/MFC-IP/.
# These entries are a safety net in case any IP file is ever copied back into
# this website repo — git will refuse to track it.
shared/
strategies/
runner/

# ── Secrets ───────────────────────────────────────────────────────────────────
.env

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── macOS system files ────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Generated outputs (re-runnable; large PNGs and CSVs not needed in git) ───
strategies/*/outputs/*.png
strategies/*/outputs/*.csv

# ── Excel lock files ──────────────────────────────────────────────────────────
~$*.xlsx
~$*.xls

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env_dir/

# ── IDE / editor ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
