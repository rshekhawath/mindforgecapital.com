# ============================================================
# MindForge Capital — Environment Variables
# ============================================================
# Copy this file to .env (same directory) and fill in your values.
# NEVER commit .env to git — it contains secrets.
#
#   cp .env.example .env
#   then edit .env with your real values
# ============================================================

# Google Apps Script deployment URL
# Get this from: Apps Script → Deploy → Manage deployments → Web App URL
MINDFORGE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID_HERE/exec
